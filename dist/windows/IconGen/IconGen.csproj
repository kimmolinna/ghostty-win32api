<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Ghostty.IconGen</RootNamespace>
    <AssemblyName>Ghostty.IconGen</AssemblyName>
    <!-- This is a build tool that runs on Windows only; suppress the
         System.Drawing.Common cross-platform warning. -->
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Drawing.Common" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Ghostty.IconGen.Tests" />
  </ItemGroup>
</Project>
